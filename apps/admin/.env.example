# ─────────────────────────────────────────────────────────────────────────────
# WDLC Admin / CMS (Next.js, port 3002) — copy to .env.local. NEVER commit real.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used by server components / route handlers).
API_URL="http://localhost:4000/api"

# Public site URL — used to trigger ISR revalidation after CMS publishes and
# for "view on site" links.
# - WEB_URL is the server-side value; NEXT_PUBLIC_WEB_URL is exposed to the browser.
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Must match the web app's REVALIDATE_SECRET so publishes can purge its cache.
# Generate with: openssl rand -hex 32.
REVALIDATE_SECRET="change-me-openssl-rand-hex-32"


# Google sign-in for the admin console (optional). The OAuth client ID; falls
# back to NEXT_PUBLIC_GOOGLE_CLIENT_ID. Leave blank to hide the button.
NEXT_PUBLIC_ADMIN_GOOGLE_CLIENT_ID=""
