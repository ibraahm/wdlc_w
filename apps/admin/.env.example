# ─────────────────────────────────────────────────────────────────────────────
# WDLC Admin / CMS (Next.js, port 3002) — copy to .env.local. NEVER commit real.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used SERVER-SIDE only — server components, route
# handlers, middleware). In production this is the INTERNAL address
# (e.g. http://127.0.0.1:4000/api); nothing here is exposed to the browser.
API_URL="http://localhost:4000/api"

# Public base URL of THIS admin console (e.g. https://secure.worlddirectlink.com).
# Used so logout (a server action) redirects to the real public host instead of
# falling back to localhost:port behind a proxy. Leave as localhost for dev.
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002"

# Public site URL — used to trigger ISR revalidation after CMS publishes and
# for "view on site" links.
# - WEB_URL is the server-side value; NEXT_PUBLIC_WEB_URL is exposed to the browser.
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Must match the web app's REVALIDATE_SECRET so publishes can purge its cache.
# Generate with: openssl rand -hex 32.
REVALIDATE_SECRET="change-me-openssl-rand-hex-32"


# Google sign-in for the admin console (optional). The OAuth client ID; falls
# back to NEXT_PUBLIC_GOOGLE_CLIENT_ID. Leave blank to hide the button.
NEXT_PUBLIC_ADMIN_GOOGLE_CLIENT_ID=""

# Shared secret for forwarding page-view analytics to the backend collector.
# Must match ANALYTICS_INGEST_KEY in the backend .env.
ANALYTICS_INGEST_KEY=""
