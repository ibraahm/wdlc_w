# ─────────────────────────────────────────────────────────────────────────────
# WDLC Public Web (Next.js, port 3000) — copy to .env.local. NEVER commit real.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# - API_URL is used server-side (SSR/route handlers, kept off the client).
# - NEXT_PUBLIC_API_URL is exposed to the browser for client-side fetches.
API_URL="http://localhost:4000/api"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Public site's own canonical URL (used for metadata / Open Graph / sitemaps).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Link to the agent portal (shown in nav / CTAs).
NEXT_PUBLIC_PORTAL_URL="http://localhost:3001"

# Secret authenticating cache-revalidation requests (POST /api/revalidate).
# Generate with: openssl rand -hex 32. Sent in the x-revalidate-token header.
# In PRODUCTION the route returns 503 if this is unset.
REVALIDATE_SECRET="change-me-openssl-rand-hex-32"
