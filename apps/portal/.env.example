# ─────────────────────────────────────────────────────────────────────────────
# WDLC Agent Portal (Next.js, port 3001) — copy to .env.local. NEVER commit real.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used by server components / route handlers).
API_URL="http://localhost:4000/api"

# reCAPTCHA v3 site key for portal login/signup (public; paired with backend secret).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# "Admin sign-in" link shown on the portal's admin-login page.
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002/login"
