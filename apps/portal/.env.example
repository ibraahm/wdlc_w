# ─────────────────────────────────────────────────────────────────────────────
# WDLC Agent Portal (Next.js, port 3001) — copy to .env.local. NEVER commit real.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used SERVER-SIDE only — server components, route
# handlers, middleware). The portal never calls the backend from the browser,
# so in production this is the INTERNAL address (e.g. http://127.0.0.1:4000/api).
API_URL="http://localhost:4000/api"

# Public base URL of THIS portal (e.g. https://portal.worlddirectlink.com).
# Used so logout (a server action) redirects to the real public host instead of
# falling back to localhost:port behind a proxy. Leave as localhost for dev.
NEXT_PUBLIC_PORTAL_URL="http://localhost:3001"

# "Admin sign-in" link shown on the portal's admin-login page (public URL).
NEXT_PUBLIC_ADMIN_URL="http://localhost:3002/login"

# Google sign-in (optional). The OAuth client ID from Google Cloud Console.
# Must match GOOGLE_CLIENT_ID on the backend. Leave blank to hide the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Shared secret for forwarding page-view analytics to the backend collector.
# Must match ANALYTICS_INGEST_KEY in the backend .env.
ANALYTICS_INGEST_KEY=""
