# Copy to .env and fill in. NEVER commit the real .env.
DATABASE_URL="file:./dev.db"

# Auth — generate strong random secrets: openssl rand -hex 32
# Set ADMIN_JWT_SECRET and AGENT_JWT_SECRET separately in production.
ADMIN_JWT_SECRET="change-me-admin-secret-openssl-rand-hex-32"
AGENT_JWT_SECRET="change-me-agent-secret-openssl-rand-hex-32"
JWT_SECRET="change-me-to-a-long-random-string"  # fallback if above not set (dev only)
JWT_EXPIRES_IN="1h"

# Seed admin (used once by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@worlddirectlink.com"
SEED_ADMIN_PASSWORD="ChangeThisOnFirstLogin!"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Frontend base URLs (used in email links)
PORTAL_BASE_URL="http://localhost:3001"
ADMIN_BASE_URL="http://localhost:3002"

# Email — SendGrid
# Leave SENDGRID_API_KEY unset (or set NODE_ENV=development) to log emails to console instead
NODE_ENV="development"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@worlddirectlink.com"
