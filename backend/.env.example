# ─────────────────────────────────────────────────────────────────────────────
# WDLC Backend (NestJS) — copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Database — PostgreSQL (required). Local example below; use a managed DB URL
# (Neon/RDS/Supabase/etc.) in staging & production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wdlc?schema=public"

# ── Auth secrets ─────────────────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
# In PRODUCTION the env validator REQUIRES ADMIN_JWT_SECRET and AGENT_JWT_SECRET
# to be set, >=32 chars, NON-placeholder, and DISTINCT from each other.
# JWT_SECRET is only a dev fallback when the per-portal secrets are unset.
ADMIN_JWT_SECRET="change-me-admin-secret-openssl-rand-hex-32"
AGENT_JWT_SECRET="change-me-agent-secret-openssl-rand-hex-32"
JWT_SECRET="change-me-to-a-long-random-string"   # dev-only fallback

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV="development"                            # development | test | production
PORT=4000
# Comma-separated list of allowed browser origins (the three frontends).
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002"
# Optional log level: fatal|error|warn|info|debug|trace|silent (defaults by env)
LOG_LEVEL="debug"

# ── Frontend base URLs (used to build links in outgoing emails) ──────────────
PORTAL_BASE_URL="http://localhost:3001"
ADMIN_BASE_URL="http://localhost:3002"

# If unset, the backend signs challenges with the configured JWT secret.
HUMAN_VERIFICATION_SECRET=""
HUMAN_VERIFICATION_TTL_SECONDS="600"

# ── Email — SendGrid ─────────────────────────────────────────────────────────
# Leave SENDGRID_API_KEY empty (or NODE_ENV=development) to log emails to the
# console instead of sending them.
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="info@worlddirectlink.com"

# Email - SMTP. If SMTP_HOST is set, SMTP is used before SendGrid.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="info@worlddirectlink.com"
SMTP_FROM_NAME="World Direct Link"

# Public Become an Agent submissions are sent here with a signed PDF attachment.
AGENT_APPLICATION_NOTIFY_EMAIL="info@worlddirectlink.com"

# ── Seed admin (used once by `npm run db:seed`) ──────────────────────────────
SEED_ADMIN_EMAIL="info@worlddirectlink.com"
SEED_ADMIN_PASSWORD="ChangeThisOnFirstLogin!"

# ── Google sign-in for the agent portal (optional) ───────────────────────────
# When set, agents whose email matches an approved portal account can sign in
# with Google. Leave blank to disable (password login is unaffected).
GOOGLE_CLIENT_ID=""

# Google sign-in for the admin console (optional). Falls back to GOOGLE_CLIENT_ID.
ADMIN_GOOGLE_CLIENT_ID=""

# ── Visitor analytics ────────────────────────────────────────────────────────
# Shared secret so only our app servers (web/portal/admin) may write page-view
# events to POST /analytics/collect. Generate with: openssl rand -hex 32
# Must match ANALYTICS_INGEST_KEY in each app's env. If unset, the endpoint
# accepts unauthenticated writes (fine for local dev, NOT for production).
ANALYTICS_INGEST_KEY=""
# Salt for the one-way IP hash used to count unique visitors. Falls back to
# JWT_SECRET if unset. Set a distinct random value in production.
ANALYTICS_IP_SALT=""
# Header your CDN/edge sets with the visitor country (ISO-3166 alpha-2).
# Defaults already include Cloudflare's CF-IPCountry; override only if your
# proxy uses a different header name.
# GEO_COUNTRY_HEADER="cf-ipcountry"
# Offline IP->country lookup (fallback when no CDN geo header is present).
# Point at a MaxMind GeoLite2 database file. GeoLite2-Country.mmdb is enough for
# country; GeoLite2-City.mmdb also yields region/city. Download free (account
# required) from maxmind.com. Leave unset to rely on CDN headers only.
# GEOIP_DB_PATH="/var/www/wdlc/backend/geoip/GeoLite2-Country.mmdb"

# ── DocuSign e-signature (admin → agent application → "Send for e-sign") ──────
# Optional. When unset, the e-sign button returns "DocuSign is not configured".
# Uses JWT Grant (the app sends on its own — no interactive login).
# Create an integration key with JWT in DocuSign Admin → Apps and Keys, generate
# an RSA key pair, and grant consent once (see the consent URL surfaced on first
# use, or DocuSign's "Grant consent" flow).
# DS_ENV="demo"                     # "demo" (sandbox) or "production"
# DS_INTEGRATION_KEY=""             # the integration (client) key
# DS_USER_ID=""                     # API user ID to impersonate (GUID)
# DS_ACCOUNT_ID=""                  # optional; defaults to the user's default account
# Provide the RSA private key inline (\n-escaped) OR as a file path:
# DS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# DS_PRIVATE_KEY_PATH="./private.key"
# DS_CONSENT_REDIRECT="https://www.docusign.com"  # a redirect URI registered on the key
