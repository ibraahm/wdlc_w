# Copy to .env and fill in. NEVER commit the real .env.
DATABASE_URL="file:./dev.db"

# Auth — generate a strong random secret (e.g. `openssl rand -hex 32`)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1h"

# Seed admin (used once by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@worlddirectlink.com"
SEED_ADMIN_PASSWORD="ChangeThisOnFirstLogin!"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:3000"
