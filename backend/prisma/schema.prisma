// PostgreSQL for parity across dev/staging/prod.
// DATABASE_URL example: postgresql://user:pass@localhost:5432/wdlc?schema=public
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ADMIN / CMS USERS  (back-office & compliance)
// Roles: SUPER_ADMIN | COMPLIANCE_OFFICER | MANAGER | EDITOR
// ─────────────────────────────────────────────
model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  role            String    @default("EDITOR")
  active          Boolean   @default(true)
  mustChangePassword Boolean @default(false)
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  lastLoginAt     DateTime?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  // For REGIONAL_OFFICER users: the office whose states scope their access.
  regionalOfficeId String?
  // For time-bound roles (e.g. AUDITOR): access is denied after this instant.
  accessExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens   AdminRefreshToken[]
  pages           Page[]
  auditLogs       AuditLog[]
}

// Refresh token per admin session - hashed, rotated on each use
model AdminRefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  adminId     String
  admin       AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([adminId])
}

// ─────────────────────────────────────────────
// AGENT / PORTAL USERS  (external agent portal)
// Status: PENDING | ACTIVE | SUSPENDED | REJECTED
// ─────────────────────────────────────────────
model AgentUser {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  firstName           String
  lastName            String
  phone               String?
  branchCode          String?   // the agent's branch the account belongs to
  role                String    @default("PRINCIPAL") // PRINCIPAL | TELLER
  active              Boolean   @default(false)  // false until email verified
  status              String    @default("PENDING")
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?   @unique
  emailVerifyExpiry   DateTime?
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  failedAttempts      Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ── Public agent-locator listing (opt-in) ──────────────────────────────
  businessName        String?
  addressLine         String?
  city                String?
  state               String?
  zip                 String?
  country             String?   @default("USA")
  publicPhone         String?
  latitude            Float?
  longitude           Float?
  showOnMap           Boolean   @default(false)

  preferredLanguage   String?   @default("en")  // default course language in the portal

  refreshTokens       AgentRefreshToken[]
  loginHistory        AgentLoginHistory[]
  auditLogs           AuditLog[]
  completions         CourseCompletion[]
  resourceAcks        ResourceAck[]
  lessonProgress      LessonProgress[]
  policyAcks          PolicyAcknowledgment[]
  trainingAssignments TrainingAssignment[]
  trainingExceptions  TrainingException[]

  @@index([showOnMap, status])
}

model AgentRefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  agentId     String
  agent       AgentUser @relation(fields: [agentId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([agentId])
}

// Per-session login history for agents (compliance requirement)
model AgentLoginHistory {
  id          String    @id @default(cuid())
  agentId     String
  agent       AgentUser @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ip          String?
  userAgent   String?
  success     Boolean
  failReason  String?
  createdAt   DateTime  @default(now())

  @@index([agentId, createdAt])
}

// ─────────────────────────────────────────────
// CMS
// ─────────────────────────────────────────────
model Page {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  description    String?
  status         String    @default("DRAFT")
  blocks         String    @default("[]")
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author         AdminUser? @relation(fields: [authorId], references: [id])
  authorId       String?

  @@index([status])
}

model NavItem {
  id       String   @id @default(cuid())
  label    String
  href     String
  location String   @default("HEADER")
  column   String?
  order    Int      @default(0)
  visible  Boolean  @default(true)

  parent   NavItem?  @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children NavItem[] @relation("NavTree")

  @@index([location, order])
}

// ─────────────────────────────────────────────
// AGENT LOCATIONS  (bulk-imported via Excel / manual admin entry)
// Separate from portal AgentUser accounts - no login required.
// ─────────────────────────────────────────────
model AgentLocation {
  id           String   @id @default(cuid())
  businessName String
  addressLine  String?
  city         String
  state        String
  zip          String?
  country      String   @default("USA")
  publicPhone  String?
  latitude     Float?
  longitude    Float?
  active       Boolean  @default(true)
  importKey    String?  @unique  // stable row identifier for re-import upserts
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
}

// ─────────────────────────────────────────────
// AGENT APPLICATIONS  (public "Become an Agent" lead form)
// Status: NEW | REVIEWING | APPROVED | REJECTED
// ─────────────────────────────────────────────
model AgentApplication {
  id                    String   @id @default(cuid())
  applicantType         String   @default("BUSINESS") // INDIVIDUAL | BUSINESS
  firstName             String
  lastName              String
  company               String?
  businessStreet        String
  businessCountry       String
  businessState         String?
  businessCity          String
  businessZip           String
  businessPhone         String
  email                 String

  howFound              String?
  howFoundOther         String?
  businessType          String?
  businessTypeOther     String?
  productsOffered       String?

  currentlyProvides     Boolean  @default(false)
  currentProvider       String?
  currentProviderOther  String?
  providedPast          Boolean  @default(false)
  pastProvider          String?
  pastProviderOther     String?
  declinedBefore        Boolean  @default(false)
  declinedExplain       String?

  preferredLanguage     String?
  preferredLanguageOther String?
  monthlyVolume         String?
  anticipatedDollarVolume String?
  totalLocations        String?
  comments              String?

  signatureName         String?
  signatureTitle        String?
  signatureConsent      Boolean  @default(false)
  signatureConsentText  String?
  signatureClientTimestamp DateTime?
  signatureAcceptedAt   DateTime?
  signatureIp           String?
  signatureUserAgent    String?

  status                String   @default("NEW")
  ip                    String?
  userAgent             String?
  createdAt             DateTime @default(now())
  updatedAt            DateTime @updatedAt

  ddFile               AgentDDFile?

  @@index([status, createdAt])
}

// ─────────────────────────────────────────────
// AGENT DUE DILIGENCE  (onboarding → ongoing DD)
// One file per agent. Mirrors the "Agent Due Diligence File Checklist"
// (BSA/AML & MSB Compliance Program). Files are stored in Dropbox; this
// record tracks the register, statuses, risk rating, and review cycle.
// ─────────────────────────────────────────────
model AgentDDFile {
  id              String    @id @default(cuid())

  // Optional link back to the originating public application (lifecycle start).
  application     AgentApplication? @relation(fields: [applicationId], references: [id])
  applicationId   String?   @unique

  branchCode      String?   @unique // 6-char agent ID, e.g. uswdlc - required before ACTIVE
  agentName       String
  entityType      String    @default("BUSINESS") // BUSINESS | INDIVIDUAL
  states          String?
  regionalOffice  String?   // human-readable label (kept for back-compat)
  regionalOfficeId String?  // FK to RegionalOffice (auto-resolved from state)

  // Branch hierarchy: PARENT (master agent) or AGENT (location). parentBranchId
  // optionally rolls an agent branch up to a parent branch.
  branchType      String    @default("AGENT") // PARENT | AGENT
  parentBranchId  String?

  // APPLICATION | UNDER_REVIEW | DD_IN_PROGRESS | ACTIVE | SUSPENDED | TERMINATED | REJECTED
  stage           String    @default("DD_IN_PROGRESS")
  riskRating      String?   // LOW | MEDIUM | HIGH

  onboardedAt     DateTime?
  lastReviewedAt  DateTime?
  reviewedBy      String?
  nextReviewDueAt DateTime?

  documents       AgentDocument[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([stage])
  @@index([nextReviewDueAt])
  @@index([regionalOfficeId])
}

// ─────────────────────────────────────────────
// REGIONAL OFFICES  (manage agents within one or more states)
// A regional office has a unique code and a CSV of the states it covers.
// Agents are auto-assigned to the office that covers their state.
// ─────────────────────────────────────────────
model RegionalOffice {
  id        String   @id @default(cuid())
  code      String   @unique          // e.g. "RO-SE"
  name      String
  states    String?                   // CSV of 2-letter state codes
  contactEmail String?
  contactPhone String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// ─────────────────────────────────────────────
// AGENT REQUESTS  (agent → regional office workflow)
// type: RISK_ASSESSMENT | LOCATION_DD | CHECKLIST | PHOTOS | OTHER
// status: OPEN | IN_REVIEW | NEEDS_INFO | APPROVED | REJECTED | CLOSED
// attachments is a JSON array: [{ name, url, kind }] (hybrid: uploaded or linked)
// ─────────────────────────────────────────────
model AgentRequest {
  id               String   @id @default(cuid())
  agentId          String                       // AgentUser who raised it
  branchCode       String?
  regionalOfficeId String?                       // routed to this office
  type             String   @default("OTHER")
  subject          String
  details          String   @default("")
  status           String   @default("OPEN")
  attachments      String   @default("[]")
  assignee         String?                       // office staff handling it
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages         AgentRequestMessage[]

  @@index([regionalOfficeId, status])
  @@index([agentId])
  @@index([branchCode])
}

model AgentRequestMessage {
  id         String   @id @default(cuid())
  requestId  String
  request    AgentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorType String   // agent | office
  authorName String?
  body       String
  createdAt  DateTime @default(now())

  @@index([requestId, createdAt])
}

// ─────────────────────────────────────────────
// RISK ASSESSMENTS  (compliance scoring per agent DD file)
// factors is a JSON array: [{ key, label, rating }] where rating is 1|2|3
// (Low/Medium/High). The overall rating is written back to AgentDDFile.riskRating.
// ─────────────────────────────────────────────
model RiskAssessment {
  id               String   @id @default(cuid())
  ddFileId         String
  branchCode       String?
  regionalOfficeId String?
  factors          String   @default("[]")
  score            Int                          // 0-100
  rating           String                       // LOW | MEDIUM | HIGH
  notes            String?
  assessedBy       String?
  createdAt        DateTime @default(now())

  @@index([ddFileId, createdAt])
  @@index([regionalOfficeId])
}

model AgentDocument {
  id          String      @id @default(cuid())
  ddFile      AgentDDFile @relation(fields: [ddFileId], references: [id], onDelete: Cascade)
  ddFileId    String

  code        String      // stable catalog key r0..r18
  section     String      // DOCUMENTATION | COMPLIANCE | ONGOING
  label       String

  present     Boolean     @default(false)
  expiry      DateTime?
  status      String      @default("MISSING") // OK | EXPIRING | EXPIRED | MISSING | NA
  notes       String?
  dropboxUrl  String?     // pointer to the file in Dropbox (file stays out-of-app)

  updatedAt   DateTime    @updatedAt

  @@unique([ddFileId, code])
  @@index([status])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// PARTNERS  (CMS-managed correspondent / integration partners)
// type: CORRESPONDENT | TECHNOLOGY | BANKING | OTHER
// ─────────────────────────────────────────────
// ─────────────────────────────────────────────
// NETWORK COUNTRIES  (CMS-managed payout destinations shown on the global map)
// payoutTypes is a JSON array of strings, e.g. ["Cash Collection","Mobile Money"]
// ─────────────────────────────────────────────
model NetworkCountry {
  id             String   @id @default(cuid())
  name           String   @unique
  payoutTypes    String   @default("[]")
  // JSON: { mobileMoney?: string[], cashPartner?: string, bankName?: string }
  payoutDetails  String   @default("{}")
  flagUrl        String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("CORRESPONDENT")
  description String?
  website     String?
  logoUrl     String?
  region      String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
}

model NewsPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  category    String    @default("NEWS") // NEWS | PRESS
  summary     String?
  body        String    @default("")
  author      String?
  imageUrl    String?
  publishedAt DateTime?
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, category])
  @@index([publishedAt])
}

// ─────────────────────────────────────────────
// FORM BUILDER  (CMS-managed forms + submissions)
// `fields` is a JSON array of field definitions (see admin form builder).
// status: DRAFT | PUBLISHED
// ─────────────────────────────────────────────
model Form {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String?
  fields         String   @default("[]")
  status         String   @default("DRAFT")
  submitLabel    String   @default("Submit")
  successMessage String   @default("Thank you - your submission has been received.")
  recaptcha      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions    FormSubmission[]

  @@index([status])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      String   @default("{}")
  status    String   @default("NEW")   // NEW | IN_PROGRESS | RESPONDED | CLOSED
  assignee  String?                      // admin name handling the case
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  messages  SubmissionMessage[]

  @@index([formId, createdAt])
  @@index([status])
}

// Threaded history for a submission: emailed replies to the submitter and
// internal notes. Append-only audit trail of how a case was handled.
model SubmissionMessage {
  id           String   @id @default(cuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  kind         String   // REPLY (emailed to submitter) | NOTE (internal)
  body         String
  toEmail      String?
  authorId     String?
  authorName   String?
  emailError   String?  // set if the reply email failed to send
  createdAt    DateTime @default(now())

  @@index([submissionId, createdAt])
}

// ─────────────────────────────────────────────
// SHARED AUDIT LOG  (append-only, never deleted)
// actorType: "admin" | "agent"
// ─────────────────────────────────────────────
model AuditLog {
  id          String    @id @default(cuid())
  action      String
  actorType   String?
  entity      String?
  entityId    String?
  before      String?
  after       String?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  admin       AdminUser? @relation(fields: [adminId], references: [id])
  adminId     String?

  agent       AgentUser? @relation(fields: [agentId], references: [id])
  agentId     String?

  @@index([entity, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TELLER APPLICATIONS - employees of an existing agent branch. Background
// check + credentialing handled by compliance; approval issues a portal login.
model TellerApplication {
  id            String   @id @default(cuid())
  branchCode    String   // provided by applicant; admin may correct it
  firstName     String
  lastName      String
  email         String
  phone         String
  addressLine   String?
  city          String?
  state         String?
  zip           String?
  signatureName String?
  signatureConsent Boolean @default(false)
  signatureIp   String?
  signatureUserAgent String?
  status        String   @default("NEW") // NEW | UNDER_REVIEW | APPROVED | REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([branchCode])
  @@index([status])
}

// ─────────────────────────────────────────────
// TRAINING / LMS  (agent & teller courses, quizzes, resources)
// Audience targeting: ALL | STATE | AGENT
//   - ALL    → every active portal user
//   - STATE  → users whose branch operates in any of targetStates (CSV of 2-letter codes)
//   - AGENT  → users whose branchCode is in targetBranches (CSV of branch codes)
// Completions are an append-only audit trail proving who took what, when, and the score.
// ─────────────────────────────────────────────
model Course {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  category      String   @default("General")
  description   String?
  contentHtml   String   @default("")   // overview / intro shown above the curriculum
  // JSON array: [{ "q": string, "options": string[], "answer": number }]
  questions     String   @default("[]") // final assessment
  passingScore  Int      @default(80)   // percent required to pass the quiz
  audience      String   @default("ALL") // ALL | STATE | AGENT
  targetStates  String?                   // CSV of 2-letter state codes (audience=STATE)
  targetBranches String?                  // CSV of branch codes (audience=AGENT)
  status        String   @default("DRAFT") // DRAFT | PUBLISHED
  order         Int      @default(0)

  // ── Corporate-LMS additions ────────────────────────────────────────────────
  language        String    @default("en")  // ISO code: en, es, fr, …
  translationGroup String?                   // links the same course across languages
  dueAt           DateTime?                  // assignment deadline (overdue if unmet)
  requireLessons  Boolean   @default(false)  // must finish all lessons before the quiz

  // ── Phase 2: policy acknowledgment ─────────────────────────────────────────
  requireAck      Boolean   @default(false)  // user must acknowledge the policy before completing
  policyStatement String?                    // exact statement shown, e.g. the policy attestation text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sections        CourseSection[]
  completions     CourseCompletion[]
  versions        CourseVersion[]
  acknowledgments PolicyAcknowledgment[]
  assignments     TrainingAssignment[]
  exceptions      TrainingException[]

  @@index([status, order])
  @@index([category])
  @@index([translationGroup])
}

// Append-only snapshot of a course's acknowledgeable content. A new version is
// minted whenever the course's title/overview/quiz/outline changes, so every
// completion and acknowledgment can point at the exact content the user saw.
model CourseVersion {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  version     Int                              // 1-based, increments per course
  title       String
  contentHtml String   @default("")
  questions   String   @default("[]")          // JSON snapshot of the quiz
  outline     String   @default("[]")          // JSON snapshot of section/lesson titles
  contentHash String                           // sha256 of the snapshotted content
  effectiveAt DateTime @default(now())          // when this content first became live
  note        String?                          // optional change note
  createdBy   String?                          // admin id, when minted via an explicit publish
  createdAt   DateTime @default(now())

  completions     CourseCompletion[]
  acknowledgments PolicyAcknowledgment[]

  @@unique([courseId, version])
  @@index([courseId])
}

// Append-only record that an agent explicitly attested to a specific course
// version ("I reviewed policy vN, effective <date>"). Immutable evidence.
model PolicyAcknowledgment {
  id              String        @id @default(cuid())
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersionId String
  courseVersion   CourseVersion @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  versionNumber   Int
  agentId         String
  agent           AgentUser     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  statement       String                       // exact attestation text shown to the user
  branchCode      String?                      // snapshot of the user's branch at the time
  ip              String?
  userAgent       String?
  acknowledgedAt  DateTime      @default(now())

  @@unique([agentId, courseVersionId])
  @@index([courseId])
  @@index([agentId])
}

// Phase 3: explicit, admin-driven assignment with rationale + deadline. Layered
// additively on audience targeting — a course is required for an agent if the
// audience matches OR an active assignment targets the agent or their branch.
// Deactivated (active=false) rather than deleted, to preserve the record.
model TrainingAssignment {
  id         String     @id @default(cuid())
  courseId   String
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  agentId    String?
  agent      AgentUser? @relation(fields: [agentId], references: [id], onDelete: Cascade)
  branchCode String?
  reason     String     // NEW_HIRE | ANNUAL | HAZARD | ROLE | REMEDIATION | OTHER
  note       String?
  dueAt      DateTime?
  active     Boolean    @default(true)
  assignedBy String?    // admin id who created the assignment
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([courseId, active])
  @@index([agentId, active])
  @@index([branchCode, active])
}

// Phase 5: documented, approved deviation from a training requirement.
// WAIVER/EQUIVALENCY excuse the learner entirely; EXTENSION moves the deadline
// to expiresAt. Only APPROVED, unexpired exceptions affect compliance.
model TrainingException {
  id          String     @id @default(cuid())
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       AgentUser? @relation(fields: [agentId], references: [id], onDelete: Cascade)
  branchCode  String?
  type        String     // WAIVER | EXTENSION | EQUIVALENCY
  reason      String
  note        String?
  status      String     @default("PENDING") // PENDING | APPROVED | REJECTED
  expiresAt   DateTime?  // EXTENSION: new deadline. WAIVER/EQUIVALENCY: optional expiry.
  requestedBy String?    // admin id who raised it
  decidedBy   String?    // admin id who approved/rejected
  decidedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([courseId, status])
  @@index([agentId, status])
  @@index([branchCode, status])
}

// A curriculum section groups ordered lessons within a course (Udemy-style).
model CourseSection {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons   Lesson[]

  @@index([courseId, order])
}

// A single lesson: rich text and/or an embedded video (YouTube/Vimeo/Loom).
model Lesson {
  id              String   @id @default(cuid())
  sectionId       String
  section         CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title           String
  order           Int      @default(0)
  contentHtml     String   @default("")
  videoUrl        String?                  // embed URL (validated/normalised in service)
  durationMinutes Int?                     // optional, shown in the outline
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress        LessonProgress[]

  @@index([sectionId, order])
}

// Per-lesson completion - powers progress %, "resume where you left off",
// and the regulator-facing evidence that each lesson was viewed.
model LessonProgress {
  id          String    @id @default(cuid())
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  agentId     String
  agent       AgentUser @relation(fields: [agentId], references: [id], onDelete: Cascade)
  completedAt DateTime  @default(now())

  @@unique([lessonId, agentId])
  @@index([agentId])
}

// Append-only audit record of a quiz attempt. The latest passing attempt
// proves completion; every attempt is retained for auditability.
model CourseCompletion {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  agentId     String
  agent       AgentUser @relation(fields: [agentId], references: [id], onDelete: Cascade)
  branchCode  String?   // snapshot of the user's branch at completion time
  agentState  String?   // snapshot of the user's resolved state(s) for reporting
  score       Int       // percent
  passed      Boolean
  // JSON array of selected option indexes, parallel to course questions
  answers     String    @default("[]")
  attempt     Int       @default(1)
  // Phase 2: the exact content version this attempt was assessed against.
  courseVersionId String?
  courseVersion   CourseVersion? @relation(fields: [courseVersionId], references: [id])
  versionNumber   Int?
  completedAt DateTime  @default(now())

  @@index([courseId, agentId])
  @@index([agentId])
  @@index([branchCode])
  @@index([passed, completedAt])
}

// A reference document / link surfaced to portal users, same audience targeting
// as courses. Acknowledgement is an audit that the user opened/read it.
model Resource {
  id            String   @id @default(cuid())
  title         String
  category      String   @default("General")
  description   String?
  url           String                     // link to the document (Dropbox, PDF, etc.)
  audience      String   @default("ALL")   // ALL | STATE | AGENT
  targetStates  String?
  targetBranches String?
  status        String   @default("DRAFT") // DRAFT | PUBLISHED
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  acks          ResourceAck[]

  @@index([status, order])
  @@index([category])
}

model ResourceAck {
  id             String    @id @default(cuid())
  resourceId     String
  resource       Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  agentId        String
  agent          AgentUser @relation(fields: [agentId], references: [id], onDelete: Cascade)
  branchCode     String?
  acknowledgedAt DateTime  @default(now())

  @@unique([resourceId, agentId])
  @@index([agentId])
}

// ─────────────────────────────────────────────
// VISIT EVENTS  (privacy-respecting traffic analytics)
// One row per page view across the public web, agent portal, and admin app.
// No raw IP is stored - only a salted hash for coarse unique-visitor counting -
// and country is derived from the edge/CDN geo header (may be null).
// portal: 'web' | 'agent' | 'admin'
// ─────────────────────────────────────────────
model VisitEvent {
  id        String   @id @default(cuid())
  portal    String
  path      String
  country   String?  // ISO 3166-1 alpha-2 (from CDN geo header), null if unknown
  region    String?
  city      String?
  ipHash    String?  // salted SHA-256 of client IP; never the raw address
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([portal, createdAt])
  @@index([country])
}
