// SQLite for zero-infra dev.
// To switch to PostgreSQL: change provider to "postgresql", update DATABASE_URL,
// and restore the Json column types — everything else stays the same.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum type — stored as String, validated in application.
// Roles: SUPER_ADMIN | COMPLIANCE_OFFICER | MANAGER | EDITOR
// PageStatus: DRAFT | PUBLISHED | ARCHIVED
// NavLocation: HEADER | FOOTER

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("EDITOR")
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pages     Page[]
  auditLogs AuditLog[]
}

// Blocks stored as a JSON string — deserialized in the service layer.
model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  description    String?
  status         String   @default("DRAFT")
  blocks         String   @default("[]")
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?

  @@index([status])
}

model NavItem {
  id       String  @id @default(cuid())
  label    String
  href     String
  location String  @default("HEADER")
  column   String?
  order    Int     @default(0)
  visible  Boolean @default(true)

  parent   NavItem?  @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children NavItem[] @relation("NavTree")

  @@index([location, order])
}

// Settings stored as JSON string, deserialized on read.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Append-only audit trail. before/after stored as JSON strings.
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String?
  entityId  String?
  before    String?
  after     String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  actor   User?   @relation(fields: [actorId], references: [id])
  actorId String?

  @@index([entity, entityId])
  @@index([createdAt])
}
